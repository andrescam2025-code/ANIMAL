          <htmlView><![CDATA[<div class="exe-text-template">
    <div id="juego-animales" style="font-family: Arial, sans-serif; line-height: 1.6; padding: 20px; border: 1px solid #ccc; border-radius: 8px; background-color: #f9f9f9;">
<h3 style="color: #2c3e50;"><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">Actividad: Clasificación de los Animales</span></span></h3>
<p><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">Completa los espacios en blanco con las palabras correctas:</span></span></p>
<div style="margin-bottom: 15px;"><strong><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">1.</span></span></strong><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;"> Los animales</span></span><input type="text" id="p1" style="padding: 5px; border: 1px solid #ccc;" /><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">se caracterizan por poseer una</span></span><input type="text" id="p2" style="padding: 5px; border: 1px solid #ccc;" /><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">vertebral y un esqueleto interno.</span></span></div>
<div style="margin-bottom: 15px;"><strong><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">2.</span></span></strong><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;"> Los animales</span></span><input type="text" id="p3" style="padding: 5px; border: 1px solid #ccc;" /><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">representan la mayoría de las especies y se definen por la ausencia de un soporte</span></span><input type="text" id="p4" style="padding: 5px; border: 1px solid #ccc;" /><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">óseo interno.</span></span></div>
<button onclick="verificarRespuestas()" style="background-color: #3498db; color: white; padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer;"><span dir="auto" style="vertical-align: inherit;"><span dir="auto" style="vertical-align: inherit;">comprobar respuestas</span></span></button>
<div id="resultado" style="margin-top: 20px; font-weight: bold;"></div>
</div>
<p>
<script>
function verificarRespuestas() {
    // Respuestas correctas (se ignoran mayúsculas/minúsculas)
    const r1 = "vertebrados";
    const r2 = "columna";
    const r3 = "invertebrados";
    const r4 = "esquelético";

    let aciertos = 0;

    if (document.getElementById('p1').value.toLowerCase().trim() === r1) aciertos++;
    if (document.getElementById('p2').value.toLowerCase().trim() === r2) aciertos++;
    if (document.getElementById('p3').value.toLowerCase().trim() === r3) aciertos++;
    
    // Verificación especial para permitir "esqueletico" con o sin tilde
    let p4 = document.getElementById('p4').value.toLowerCase().trim();
    if (p4 === "esquelético" || p4 === "esqueletico") aciertos++;

    const resultadoDiv = document.getElementById('resultado');
    if (aciertos === 4) {
        resultadoDiv.style.color = "#27ae60";
        resultadoDiv.innerHTML = "¡Excelente! Has completado todas las oraciones correctamente.";
    } else {
        resultadoDiv.style.color = "#e74c3c";
        resultadoDiv.innerHTML = "Has acertado " + aciertos + " de 4. ¡Sigue intentándolo!";
    }
}
</script>
</p>
</div>]]></htmlView>
